{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-swarm.local/schemas/ledger-event.schema.json",
  "title": "Agent Swarm Ledger Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["ts", "run_id", "loop", "round", "event", "status", "payload"],
  "properties": {
    "ts": { "type": "string", "pattern": "Z$" },
    "run_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+$" },
    "loop": { "type": "string", "enum": ["planning", "execution"] },
    "round": { "type": "integer", "minimum": 1 },
    "event": {
      "type": "string",
      "enum": ["review", "replan-request", "replan-consumed", "fix-request", "fix-consumed", "validation", "final"]
    },
    "status": { "type": "string", "minLength": 1 },
    "payload": { "type": "object" }
  }
}
